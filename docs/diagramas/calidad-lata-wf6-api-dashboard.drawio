<mxfile host="app.diagrams.net" type="device">
  <diagram id="calidad-lata-wf6" name="WF6 — API Dashboard (datos + imagen)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageWidth="1700" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="WF6 — API Dashboard (cfcBsJ1PcnseFZfu) · dos endpoints con CORS a dashboard.cluna.ar · 13/07/2026" style="text;html=1;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1100" height="30" as="geometry"/></mxCell>

        <mxCell id="spa" value="📊 Dashboard (SPA React)&#10;https://dashboard.cluna.ar&#10;KPIs · 4 gráficos · filtros · tabla&#10;· modal de detalle con foto" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="280" width="240" height="110" as="geometry"/></mxCell>

        <mxCell id="lane1" value="Endpoint 1 — datos (fetch JSON)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#666666;dashed=1;verticalAlign=top;fontStyle=1" vertex="1" parent="1"><mxGeometry x="360" y="100" width="1000" height="180" as="geometry"/></mxCell>
        <mxCell id="wh1" value="🌐 Webhook&#10;GET /webhook/dashboard-calidad" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="390" y="150" width="230" height="70" as="geometry"/></mxCell>
        <mxCell id="pg1" value="🐘 Evidencias 90 días&#10;evidencias LEFT JOIN resultados&#10;+ latencia_segundos =&#10;evaluado_en − capturado_en" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="700" y="140" width="250" height="90" as="geometry"/></mxCell>
        <mxCell id="resp1" value="↩️ Responder JSON&#10;(header CORS + no-store)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="1030" y="150" width="220" height="70" as="geometry"/></mxCell>

        <mxCell id="lane2" value="Endpoint 2 — imagen original (el modal la carga con &lt;img&gt;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#666666;dashed=1;verticalAlign=top;fontStyle=1" vertex="1" parent="1"><mxGeometry x="360" y="330" width="1000" height="330" as="geometry"/></mxCell>
        <mxCell id="wh2" value="🌐 Webhook&#10;GET /webhook/dashboard-calidad-imagen&#10;?id=&lt;evidence_id&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="390" y="390" width="240" height="80" as="geometry"/></mxCell>
        <mxCell id="pg2" value="🐘 Buscar imagen_ref&#10;SELECT imagen_ref FROM evidencias&#10;WHERE evidence_id = $1&#10;(parametrizada — sin inyección)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="700" y="385" width="250" height="90" as="geometry"/></mxCell>
        <mxCell id="s3" value="🗄 Descargar imagen&#10;MinIO bucket calidad-lata&#10;(key = imagen_ref)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="1030" y="370" width="170" height="110" as="geometry"/></mxCell>
        <mxCell id="resp2" value="↩️ Responder imagen&#10;binario image/jpeg&#10;Cache-Control 24 h" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="1030" y="540" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="resp404" value="⛔ Imagen no encontrada&#10;HTTP 404&#10;(id inexistente o sin imagen_ref)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="700" y="540" width="230" height="80" as="geometry"/></mxCell>

        <mxCell id="nota" value="🔒 CORS: ambos webhooks con allowedOrigins = https://dashboard.cluna.ar. La latencia (criterio 23) se muestra por evidencia y como KPI p95. La foto (criterios 1 y 22) sale de MinIO — evidencia auditable sin acceso a la infraestructura." style="text;html=1;fontSize=11;fontColor=#666666;" vertex="1" parent="1"><mxGeometry x="360" y="700" width="1000" height="40" as="geometry"/></mxCell>

        <mxCell id="e1" value="fetch datos" style="endArrow=block;html=1;" edge="1" parent="1" source="spa" target="wh1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=block;html=1;" edge="1" parent="1" source="wh1" target="pg1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="endArrow=block;html=1;" edge="1" parent="1" source="pg1" target="resp1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="clic en fila → &lt;img&gt;" style="endArrow=block;html=1;" edge="1" parent="1" source="spa" target="wh2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="endArrow=block;html=1;" edge="1" parent="1" source="wh2" target="pg2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="imagen_ref" style="endArrow=block;html=1;" edge="1" parent="1" source="pg2" target="s3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="ok" style="endArrow=block;html=1;" edge="1" parent="1" source="s3" target="resp2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" value="error (rama de error)" style="endArrow=block;html=1;dashed=1;" edge="1" parent="1" source="s3" target="resp404"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
