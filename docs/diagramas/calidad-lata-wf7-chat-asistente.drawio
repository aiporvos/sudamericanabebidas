        <mxCell id="memory" value="🗂 Simple Memory&#10;sessionKey = session_id&#10;ventana 20 turnos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="1150" y="260" width="200" height="80" as="geometry"/></mxCell>

        <mxCell id="lane" value="WF7b — Tool &quot;Consultar evidencias de Calidad&quot; (sub-workflow, DEBE estar activo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#666666;dashed=1;verticalAlign=top;fontStyle=1" vertex="1" parent="1"><mxGeometry x="920" y="420" width="700" height="260" as="geometry"/></mxCell>
        <mxCell id="ewt" value="⚙️ Entrada de la tool&#10;modo · dias_atras · linea · resultado&#10;(par&#225;metros $fromAI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="950" y="470" width="230" height="90" as="geometry"/></mxCell>
        <mxCell id="ifmodo" value="¿modo =&#10;'resumen'?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="1220" y="475" width="120" height="80" as="geometry"/></mxCell>
        <mxCell id="pgres" value="🐘 Resumen por línea&#10;GROUP BY linea: total,&#10;OK/No OK/revisión/incoherentes/&#10;confianza media/tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="1400" y="440" width="200" height="100" as="geometry"/></mxCell>
