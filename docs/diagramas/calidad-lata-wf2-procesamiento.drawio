<mxfile host="app.diagrams.net" type="device">
  <diagram id="wf2-procesamiento" name="WF2 — Procesamiento IA (Cola → Resultado)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageWidth="1750" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="WF2 — Procesamiento IA v2 según minuta 25/06 (ID yCCNYSU11G5hgWPV)" style="text;html=1;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="900" height="30" as="geometry"/></mxCell>
        <mxCell id="rmq" value="🐰 RabbitMQ Trigger&#10;consume la cola&#10;calidad.lata.procesar" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="40" y="120" width="170" height="80" as="geometry"/></mxCell>
        <mxCell id="s3" value="🗄 Descargar imagen&#10;de MinIO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="260" y="120" width="150" height="80" as="geometry"/></mxCell>
        <mxCell id="vision" value="🧠 Visión IA (OpenAI gpt-4o)&#10;1) clasifica tipo_foto: tapa /&#10;fondo_impresion / pantalla_contador / frente&#10;2) extrae según tipo: contadores + hora_pantalla,&#10;textos impresos (L:, V:), calidad_impresion,&#10;defectos · JSON estricto" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="460" y="100" width="300" height="120" as="geometry"/></mxCell>
        <mxCell id="parse" value="🔧 Parsear resultado&#10;umbral confianza 0.85&#10;tokens (medición de costo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="810" y="120" width="190" height="80" as="geometry"/></mxCell>
        <mxCell id="lookup" value="🐘 Buscar contador reciente&#10;última pantalla_contador de&#10;la MISMA línea (±90 min)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="1050" y="120" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="coh" value="⚖️ Evaluar coherencia (3 chequeos)&#10;① LOTE impreso vs pantalla&#10;② VENCIMIENTO impreso vs pantalla&#10;③ HORA impresa vs pantalla (±90 min)&#10;cualquier falla → No OK + motivo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="1300" y="100" width="250" height="120" as="geometry"/></mxCell>
        <mxCell id="save" value="🐘 Guardar resultado (Postgres)&#10;tipo_foto · textos · etiquetas · hora_pantalla&#10;calidad_impresion · coherencia · motivo · tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="1300" y="290" width="250" height="90" as="geometry"/></mxCell>
        <mxCell id="ifatn" value="¿Requiere&#10;atención?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="1060" y="295" width="120" height="80" as="geometry"/></mxCell>
        <mxCell id="alert" value="⚠️ Alerta Telegram (HTML lindo)&#10;No OK · baja confianza · mala impresión&#10;· incoherencia → con motivo + evidencia" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="700" y="270" width="260" height="80" as="geometry"/></mxCell>
        <mxCell id="finok" value="✅ Fin OK&#10;(sin ruido)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="740" y="400" width="120" height="60" as="geometry"/></mxCell>
        <mxCell id="nota" value="Fallback (minuta): confianza &lt; 0.85 → revision_manual=true, NO se fuerza OK/No OK → alerta + bandeja de revisión (WF4)" style="text;html=1;fontSize=11;fontColor=#666666;" vertex="1" parent="1"><mxGeometry x="40" y="480" width="800" height="30" as="geometry"/></mxCell>
        <mxCell id="e1" style="endArrow=block;html=1;" edge="1" parent="1" source="rmq" target="s3"><mxGeometry relative="1" as="geometry"/></mxCell>
