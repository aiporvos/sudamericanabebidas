        <mxCell id="e5" value="No (fallback)" style="endArrow=block;html=1;" edge="1" parent="1" source="g1" target="t4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="Sí" style="endArrow=block;html=1;" edge="1" parent="1" source="g1" target="g2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="No" style="endArrow=block;html=1;" edge="1" parent="1" source="g2" target="t5"><mxGeometry relative="1" as="geometry"/></mxCell>
