<mxfile host="app.diagrams.net" type="device">
  <diagram id="calidad-lata-bpmn" name="Calidad de Lata — Proceso (BPMN)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageWidth="1750" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Proceso Calidad de Lata — BPMN (v2, minuta 25/06/2026)" style="text;html=1;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="700" height="30" as="geometry"/></mxCell>
        <mxCell id="start" value="⏱ Cada hora:&#10;operario fotografía&#10;(tapa, fondo, pantalla, frente)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="40" y="120" width="180" height="90" as="geometry"/></mxCell>
        <mxCell id="t1" value="Enviar foto al grupo&#10;Telegram de la línea" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="270" y="130" width="170" height="70" as="geometry"/></mxCell>
        <mxCell id="t2" value="Sistema recibe, conserva&#10;imagen original y registra&#10;hora de envío" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="490" y="130" width="190" height="70" as="geometry"/></mxCell>
        <mxCell id="t3" value="IA clasifica tipo de foto&#10;y extrae datos&#10;(contadores, hora en pantalla,&#10;textos impresos, defectos)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="730" y="120" width="220" height="90" as="geometry"/></mxCell>
        <mxCell id="g1" value="¿Lectura&#10;confiable?&#10;(≥85%)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="1000" y="115" width="120" height="100" as="geometry"/></mxCell>
        <mxCell id="t4" value="Revisión manual:&#10;operador confirma /&#10;corrige / rechaza&#10;(queda autor + hora)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="990" y="290" width="180" height="90" as="geometry"/></mxCell>
        <mxCell id="g2" value="¿Impresión correcta&#10;y coherente con la&#10;pantalla? (lote, vto,&#10;hora, calidad)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="1180" y="105" width="170" height="120" as="geometry"/></mxCell>
        <mxCell id="t5" value="🚨 Alerta inmediata al grupo&#10;con evidencia, motivo y timestamp&#10;(desvío detectado en tiempo real)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="1400" y="250" width="240" height="80" as="geometry"/></mxCell>
        <mxCell id="t6" value="Registrar OK en base única&#10;(sin duplicados, consultable&#10;por fecha/línea/proceso)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="1400" y="120" width="220" height="80" as="geometry"/></mxCell>
        <mxCell id="end" value="📊 Datos para indicadores,&#10;reportes y reclamos&#10;(sin reprocesar planillas)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="1420" y="430" width="200" height="90" as="geometry"/></mxCell>
        <mxCell id="e1" style="endArrow=block;html=1;" edge="1" parent="1" source="start" target="t1"><mxGeometry relative="1" as="geometry"/></mxCell>
